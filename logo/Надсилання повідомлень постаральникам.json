      "parameters": {
        "jsCode": "// Отримує всі binary дані з webhook (включно з файлом)\nconst binaryData = $('Webhook').item.binary || {};\n\n// Бере Chat ID та Message Thread ID з Google Sheets\nconst sheetsData = $('Get row(s) in sheet').first().json;\nconst chatId = sheetsData.chatId;\nconst messageThreadId = sheetsData.messageThreadId;\n\nreturn {\n  json: {\n    chat_id: chatId,\n    caption: \"Добрий день,прошу прийняти замовлення\",\n    message_thread_id: messageThreadId\n  },\n  binary: binaryData\n};"
      },
