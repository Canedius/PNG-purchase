    {
      "parameters": {
        "jsCode": "const message = items[0].json.message;\nconst chatTitle = message.chat.title || message.chat.first_name || 'Unknown';\nconst chatId = message.chat.id;\nconst messageThreadId = message.message_thread_id || null;\n\nreturn [{\n  json: {\n    partnerName: chatTitle,\n    chatId: chatId.toString(),\n    messageThreadId: messageThreadId ? messageThreadId.toString() : ''\n  }\n}];"
      },
